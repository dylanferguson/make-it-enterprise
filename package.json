{
  "name": "make-it-enterprise-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Disposable Docker sandbox that loops an AI agent over the seed/ project.",
  "scripts": {
    "sandbox:agent": "docker compose run --rm agent",
    "sandbox:build": "docker compose build agent",
    "sandbox:check": "sh scripts/check-sandbox.sh",
    "sandbox:export": "sh scripts/export-sandbox.sh",
    "sandbox:loop": "docker compose run --rm agent enterprise-loop",
    "sandbox:reset": "sh scripts/reset-sandbox.sh",
    "sandbox:shell": "docker compose run --rm agent bash",
    "sandbox:test": "docker compose run --rm agent pnpm test"
  },
  "packageManager": "pnpm@11.2.2"
}
