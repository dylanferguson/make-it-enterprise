<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd"
       version="4.0"
       bean-discovery-mode="all">
  <scan>
    <exclude name="com.fizzbuzz.enterprise.test.**"/>
  </scan>
  <interceptors>
    <class>com.fizzbuzz.enterprise.interceptor.AuditTrailSessionInterceptor</class>
    <class>com.fizzbuzz.enterprise.interceptor.EnterpriseInterceptorChainImpl</class>
  </interceptors>
  <decorators>
    <class>com.fizzbuzz.enterprise.patterns.CachingValueResolverDecorator</class>
    <class>com.fizzbuzz.enterprise.patterns.RetryValueResolverDecorator</class>
    <class>com.fizzbuzz.enterprise.patterns.FallbackValueResolverDecorator</class>
  </decorators>
  <alternatives>
    <class>com.fizzbuzz.enterprise.impl.strategies.StandardRemainderModuloEvaluationStrategyImpl</class>
  </alternatives>
</beans>
