<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
  <persistence-unit name="FizzBuzzEnterprisePersistenceUnit" transaction-type="JTA">
    <provider>com.fizzbuzz.enterprise.persistence.FizzBuzzEntityPersistenceProvider</provider>
    <jta-data-source>java:comp/env/jdbc/FizzBuzzDataSource</jta-data-source>
    <class>com.fizzbuzz.enterprise.entities.FizzBuzzEntityBeanImpl</class>
    <class>com.fizzbuzz.enterprise.entities.FizzBuzzValueEntity</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
    <shared-cache-mode>ENABLE_SELECTIVE</shared-cache-mode>
    <validation-mode>CALLBACK</validation-mode>
    <properties>
      <property name="jakarta.persistence.schema-generation.database.action" value="create-or-drop-tables"/>
      <property name="jakarta.persistence.schema-generation.create-source" value="metadata"/>
      <property name="jakarta.persistence.sql-load-script-source" value="META-INF/sql/seed-fizzbuzz-data.sql"/>
      <property name="jakarta.persistence.cache.storeMode" value="BYPASS"/>
      <property name="jakarta.persistence.cache.retrieveMode" value="BYPASS"/>
      <property name="jakarta.persistence.lock.timeout" value="30000"/>
      <property name="jakarta.persistence.query.timeout" value="10000"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.FizzBuzzEnterpriseDialect"/>
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.hbm2ddl.auto" value="validate"/>
      <property name="hibernate.c3p0.min_size" value="5"/>
      <property name="hibernate.c3p0.max_size" value="20"/>
      <property name="hibernate.c3p0.timeout" value="300"/>
      <property name="hibernate.c3p0.max_statements" value="50"/>
      <property name="hibernate.c3p0.idle_test_period" value="3000"/>
    </properties>
  </persistence-unit>
</persistence>
