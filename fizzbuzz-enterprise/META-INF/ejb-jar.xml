<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ejb-jar PUBLIC "-//Sun Microsystems, Inc.//DTD Enterprise JavaBeans 2.0//EN" "http://java.sun.com/dtd/ejb-jar_2_0.dtd">
<ejb-jar>
  <display-name>FizzBuzzEnterpriseComputationEngine</display-name>
  <enterprise-beans>
    <session>
      <display-name>FizzBuzzComputationEJB</display-name>
      <ejb-name>FizzBuzzComputationEJB</ejb-name>
      <home>com.enterprise.fizzbuzz.ejb.contracts.IEjbHome</home>
      <remote>com.enterprise.fizzbuzz.ejb.contracts.IEjbObject</remote>
      <ejb-class>com.enterprise.fizzbuzz.ejb.impl.FizzBuzzComputationEjbSessionBeanImpl</ejb-class>
      <session-type>Stateless</session-type>
      <transaction-type>Container</transaction-type>
      <env-entry>
        <env-entry-name>fizzbuzz/computation/divisor/three</env-entry-name>
        <env-entry-type>java.lang.Integer</env-entry-type>
        <env-entry-value>3</env-entry-value>
      </env-entry>
      <env-entry>
        <env-entry-name>fizzbuzz/computation/divisor/five</env-entry-name>
        <env-entry-type>java.lang.Integer</env-entry-type>
        <env-entry-value>5</env-entry-value>
      </env-entry>
      <resource-ref>
        <res-ref-name>jms/FizzBuzzComputationQueue</res-ref-name>
        <res-type>javax.jms.Queue</res-type>
        <res-auth>Container</res-auth>
      </resource-ref>
    </session>
  </enterprise-beans>
  <assembly-descriptor>
    <container-transaction>
      <method>
        <ejb-name>FizzBuzzComputationEJB</ejb-name>
        <method-name>*</method-name>
      </method>
      <trans-attribute>Required</trans-attribute>
    </container-transaction>
  </assembly-descriptor>
</ejb-jar>
